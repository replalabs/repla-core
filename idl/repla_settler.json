{
  "version": "0.1.0",
  "name": "repla_settler",
  "address": "ReplaSettLerXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
  "instructions": [
    {
      "name": "initialize_registry",
      "accounts": [
        { "name": "registry", "isMut": true, "isSigner": false },
        { "name": "admin", "isMut": true, "isSigner": true },
        { "name": "system_program", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "fee_bps", "type": "u16" },
        { "name": "buyback_bps", "type": "u16" },
        { "name": "settle_lag", "type": "u64" },
        { "name": "fee_per_action", "type": "u64" },
        { "name": "min_stake", "type": "u64" }
      ]
    },
    {
      "name": "register_sequencer",
      "accounts": [
        { "name": "registry", "isMut": true, "isSigner": false },
        { "name": "sequencer", "isMut": true, "isSigner": false },
        { "name": "operator", "isMut": true, "isSigner": true },
        { "name": "system_program", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "stake_amount", "type": "u64" }
      ]
    },
    {
      "name": "register_l3",
      "accounts": [
        { "name": "registry", "isMut": true, "isSigner": false },
        { "name": "l3", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "system_program", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "l3_id", "type": { "array": ["u8", 32] } },
        { "name": "slot_time_ms", "type": "u32" },
        { "name": "settle_interval_slots", "type": "u32" }
      ]
    },
    {
      "name": "settle_state",
      "accounts": [
        { "name": "registry", "isMut": true, "isSigner": false },
        { "name": "l3", "isMut": true, "isSigner": false },
        { "name": "sequencer", "isMut": true, "isSigner": false },
        { "name": "settlement", "isMut": true, "isSigner": false },
        { "name": "operator", "isMut": true, "isSigner": true },
        { "name": "system_program", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "l3_id", "type": { "array": ["u8", 32] } },
        { "name": "from_slot", "type": "u64" },
        { "name": "to_slot", "type": "u64" },
        { "name": "state_root", "type": { "array": ["u8", 32] } },
        { "name": "action_count", "type": "u32" }
      ]
    },
    {
      "name": "slash_sequencer",
      "accounts": [
        { "name": "registry", "isMut": true, "isSigner": false },
        { "name": "sequencer", "isMut": true, "isSigner": false },
        { "name": "admin", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "slash_amount", "type": "u64" },
        { "name": "reason_code", "type": "u8" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "Registry",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "admin", "type": "publicKey" },
          { "name": "fee_bps", "type": "u16" },
          { "name": "buyback_bps", "type": "u16" },
          { "name": "settle_lag", "type": "u64" },
          { "name": "fee_per_action", "type": "u64" },
          { "name": "min_stake", "type": "u64" },
          { "name": "max_slashes", "type": "u8" },
          { "name": "total_sequencers", "type": "u64" },
          { "name": "total_l3s", "type": "u64" },
          { "name": "total_settlements", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "Sequencer",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "operator", "type": "publicKey" },
          { "name": "stake", "type": "u64" },
          { "name": "slash_count", "type": "u8" },
          { "name": "settled_count", "type": "u64" },
          { "name": "earnings", "type": "u64" },
          { "name": "registered_at", "type": "i64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "L3Account",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "owner", "type": "publicKey" },
          { "name": "l3_id", "type": { "array": ["u8", 32] } },
          { "name": "slot_time_ms", "type": "u32" },
          { "name": "settle_interval_slots", "type": "u32" },
          { "name": "last_settled_slot", "type": "u64" },
          { "name": "settlement_count", "type": "u64" },
          { "name": "created_at", "type": "i64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "Settlement",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "l3_id", "type": { "array": ["u8", 32] } },
          { "name": "from_slot", "type": "u64" },
          { "name": "to_slot", "type": "u64" },
          { "name": "state_root", "type": { "array": ["u8", 32] } },
          { "name": "action_count", "type": "u32" },
          { "name": "sequencer", "type": "publicKey" },
          { "name": "settled_at", "type": "i64" },
          { "name": "fee_total", "type": "u64" },
          { "name": "fee_burn", "type": "u64" },
          { "name": "fee_sequencer", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "events": [
    { "name": "RegistryInitialized", "fields": [] },
    { "name": "SequencerRegistered", "fields": [] },
    { "name": "L3Registered", "fields": [] },
    { "name": "StateSettled", "fields": [] },
    { "name": "SequencerSlashed", "fields": [] }
  ],
  "errors": [
    { "code": 6000, "name": "InvalidParam", "msg": "Invalid parameter" },
    { "code": 6001, "name": "StakeTooLow", "msg": "Stake amount below minimum" },
    { "code": 6002, "name": "InvalidSlotRange", "msg": "Invalid slot range" },
    { "code": 6003, "name": "NonMonotonicSlot", "msg": "Non-monotonic slot" },
    { "code": 6004, "name": "SettleLagNotMet", "msg": "Settle lag not yet met" },
    { "code": 6005, "name": "SequencerSlashed", "msg": "Sequencer has reached max slashes" },
    { "code": 6006, "name": "SlashExceedsStake", "msg": "Slash amount exceeds sequencer stake" },
    { "code": 6007, "name": "Overflow", "msg": "Arithmetic overflow" }
  ]
}
